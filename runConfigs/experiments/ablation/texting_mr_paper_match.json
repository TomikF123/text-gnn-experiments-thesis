{
    "experiment_name": "ablation_texting",
    "run_name": "texting_mr_paper_match",
    "dataset": {
        "name": "mr",
        "tvt_split": [0.6, 0.07, 0.33],
        "shuffle": true,
        "random_seed": 42,
        "preprocess": {
            "remove_stopwords": true,
            "remove_rare_words": 0
        },
        "gnn_encoding": {
            "window_size": 3,
            "embedding_dim": 300
        },
        "max_len": null
    },
    "model_config": {
        "model_type": "texting",
        "common_params": {
            "epochs": 200,
            "batch_size": 4096,
            "seed": 42,
            "device": "cuda"
        },
        "model_specific_params": {
            "hidden_dim": 96,
            "gru_steps": 2,
            "dropout": 0.5,
            "lr": 0.01,
            "weight_decay": 0,
            "patience": 15
        }
    }
}
